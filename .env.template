# [Ref: 03_原子目标与规约/_共享规约/02_三位一体仓库规约] 占位，禁止填写真实 Key
# 与 diting-core .env.template 一致（应用变量以 core 为权威）；可多出 infra 专用项（如 ACR、TF_VAR_*）
# 本地实践时：在 diting-core 复制其 .env.template 为 .env 并填写；本文件供 infra 侧文档/Secret 键名参考

API_KEY=
DB_URL=

# L1 TimescaleDB（OHLCV）；示例：postgresql://user:pass@host:port/dbname；本地 compose 端口 15432
TIMESCALE_DSN=

# Redis；示例：redis://:pass@host:6379/0
REDIS_URL=

# L2 知识库 PostgreSQL；示例：postgresql://user:pass@host:5432/dbname；本地 compose 端口 15433
PG_L2_DSN=
