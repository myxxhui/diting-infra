# ACR 拉取凭证示例（本 Chart 附属 manifest，与 ingest Job 的 imagePullSecrets 配套）
# 使用方式：复制为 acr-pull-secret.yaml 并替换 data.".dockerconfigjson" 为实际 base64 内容
# 含真实凭证的 acr-pull-secret.yaml 已加入仓库 .gitignore，可从项目安全渠道获取或按下方生成
#
# 生成 .dockerconfigjson base64（将 <REGISTRY> <USER> <PASSWORD> 替换为实际值）：
#   echo -n '{"auths":{"<REGISTRY>":{"username":"<USER>","password":"<PASSWORD>","auth":"'$(echo -n "<USER>:<PASSWORD>" | base64)'"}}}' | base64
# 示例（阿里云 ACR 香港个人版）：REGISTRY=crpi-7vifw4ok9jkcxr60.cn-hongkong.personal.cr.aliyuncs.com
#
apiVersion: v1
kind: Secret
metadata:
  name: acr-titan
  namespace: default
  labels:
    app: diting
    component: acr-pull
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: "<REPLACE_WITH_BASE64_DOCKERCONFIGJSON>"
