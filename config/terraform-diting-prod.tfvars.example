# 复制为 terraform-diting-prod.tfvars 后填写。instance_password 勿提交，用 TF_VAR_instance_password 注入。make down 仅释放 ECS/EIP。

env_id            = "prod"
region            = "cn-hongkong"
instance_type     = "ecs.u1-c1m4.xlarge"
# instance_password 用 export TF_VAR_instance_password='...' 注入
vpc_cidr          = "10.0.0.0/16"
vswitch_cidr      = "10.0.1.0/24"
enable_spot       = true
spot_strategy     = "SpotAsPriceGo"
spot_price_limit  = 0.5
eip_bandwidth     = 100
disk_category     = "cloud_essd"

# 固定资源 ID（复用时填，格式示例: vpc-bp1xxx vsw-bp1xxx sg-bp1xxx nas_id 访问组名）
vpc_existing_id      = ""
vswitch_existing_id  = ""
security_group_existing_id  = ""
nas_existing_file_system_id    = ""
nas_existing_access_group_name = ""
# 磁盘ID固定参数（填则固定挂载该盘，如 d-j6c4rf72n4bxwtodo515；不填则 Make 从 prod.disk_id 注入）
use_existing_data_disk_id      = ""

enable_prod_data_disk = true
data_disk_size        = 100
data_disk_category    = "cloud_essd"

oss_bucket_name   = "deploy-engine-k3s-storage"
oss_bucket_acl    = "public-read-write"
init_script_acl   = "public-read"
